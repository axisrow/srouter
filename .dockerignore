# Docker build-context фильтр (cycle-review #114 C1).
# .gitignore НЕ фильтрует Docker — COPY . утащил бы секреты в слой образа (srouter.local.json с
# Reality-материалом/UUID/endpoints, srouter_config.py, .env). Этот файл — зеркало секретных/локальных
# паттернов .gitignore ПЛЮС .git и кэши (раздувают context, не нужны в образе).

# Локальная конфигурация (реальные адреса инфраструктуры, Reality-материал, UUID узлов)
srouter_config.py
srouter.local.json
# cycle-review #114 C3: save_state atomic-write temp (local_state.py:596). ВАЖНО: комментарий на
# ОТДЕЛЬНОЙ строке — Docker/git парсят '#' как комментарий только в начале строки, inline-коммент
# ломает паттерн (C4), и файл с секретами утекает в образ.
srouter.local.json.tmp
# _backup() timestamped — прежний (чужой) конфиг с секретами (install_lib.py:599)
*.srouter-backup-*

# Privacy: локальный кэш hot_routes (домены+счётчики)
srouter.hot_routes.json
srouter.hot_routes.json.tmp

# Секреты окружения. RECURSIVE (cycle-review #114 C5): Docker glob без ** матчит ТОЛЬКО корень
# контекста, НЕ поддиректории. server/.env (Reality-секреты XRAY_PRIVATE_KEY/UUID/SHORT_ID,
# server/README.md) без ** утащился бы в образ. **/.env покрывает все уровни.
**/.env
**/.env.*
**/*.env
!**/.env.example

# Сгенерированные серверные артефакты и ключи. RECURSIVE (cycle-review #114 C5): Docker glob без **
# матчит только корень. server/rendered/node.json и server/.generated/ содержат Reality-ключи.
server/.generated/
server/generated/
server/rendered/
server/deploy-bundles/
server/**/*.env
server/**/node_object.json
server/**/node.json

# Local MCP config (may contain API keys)
.mcp.json

# Git — не нужен в образе, раздувает build-context
.git
.gitignore

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
*.egg-info/
build/
dist/

# Бэкапы и временное
*.bak
*.bak-*
dashboard.py.bak-*

# Диагностика с реальными сетевыми данными
diag-vpn.txt
diag-*.txt

# Служебные экспорты сессий
*local-command-caveat*.md

# Docker-локальная настройка (не публиковать)
.claude/
