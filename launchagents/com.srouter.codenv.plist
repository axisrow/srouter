<?xml version="1.0" encoding="UTF-8"?>
<!-- __SROUTER_CODENV_MARKER__ -->
<!-- Codex global SOCKS5 env: launchctl setenv SOCKS5 в GUI-домен launchd (видят все GUI-приложения).
     RunAtLoad (при входе/ребут) + каждые 5мин (переживает ребут — launchctl setenv сам по себе нет).
     Скрипт srouter-codex-env.sh выставляет HTTP_PROXY/HTTPS_PROXY/ALL_PROXY=socks5h://127.0.0.1:10808
     + NO_PROXY=localhost,127.0.0.1,::1. Claude.app/ChatGPT.app на System Settings SOCKS — global env
     их не ломает. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>__SROUTER_CODENV_LABEL__</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>__SROUTER_CODENV_PATH__</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>StandardOutPath</key>
  <string>__SROUTER_LOG_OUT__</string>
  <key>StandardErrorPath</key>
  <string>__SROUTER_LOG_ERR__</string>
</dict>
</plist>
